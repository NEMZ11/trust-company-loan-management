# Use a hosted PostgreSQL connection string for the public deployment.
# Example shape:
# DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE?sslmode=require"
DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE?sslmode=require"

# Generate a long random value before launch. Do not reuse the local demo secret.
APP_SESSION_SECRET="replace-with-a-long-random-production-secret"
